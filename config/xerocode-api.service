[Unit]
Description=Xerocode.ai API
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/ubuntu/xerocode-api
Environment=NODE_ENV=production
EnvironmentFile=-/home/ubuntu/xerocode-api/.env
ExecStart=/usr/bin/node index.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
